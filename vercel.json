{
  "version": 2,
  "plugins": [
    { "src": "vercel-php", "config": { "force_node_version": "20.x" } }
  ],
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}