{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|webp|json|xml|txt|pdf)$",
      "dest": "/public/$0"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}